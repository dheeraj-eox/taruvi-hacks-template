# Taruvi Hackathon Configuration
# Fill in TARUVI_SITE_URL, TARUVI_APP_SLUG, and TARUVI_API_KEY
# from the "Your environment values" section on the onboarding page (step 7).
# Then click 🔑 Connect Codex in the status bar — it will fetch the rest automatically.

# Base URL of your company's Taruvi site (e.g. https://acme-hackathon-2026.taruvi.cloud)
TARUVI_SITE_URL=

# Your app slug (e.g. my-app)
TARUVI_APP_SLUG=

# Your app API key (from Settings → Connect → Generate API Key)
TARUVI_API_KEY=

# AI provider key — added automatically by scripts/start-codex-devcontainer.sh (do not fill manually)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
